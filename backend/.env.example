NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/roastmaster_ai
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roastmaster_ai
DB_USER=postgres
DB_PASSWORD=password

# Server
PORT=5000
HOST=0.0.0.0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ROEST Connect API (if integrating)
ROEST_API_BASE_URL=https://connect.roestcoffee.com/api
ROEST_API_KEY=your_roest_api_key

# Socket.IO
SOCKET_IO_CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=info
